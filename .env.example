# OpenAI-compatible API (OpenAI, Azure, local vLLM, etc.)
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Service
SELF_HEALER_HOST=0.0.0.0
SELF_HEALER_PORT=8080
SELF_HEALER_LOG_LEVEL=INFO

# Safety
SELF_HEALER_AUTO_EXECUTE=false
SELF_HEALER_MAX_RECOVERY_STEPS=5
SELF_HEALER_COMMAND_TIMEOUT_SECONDS=30

# Docker sandbox
SELF_HEALER_SANDBOX_IMAGE=self-healer-sandbox:latest
SELF_HEALER_SANDBOX_MEMORY_LIMIT=256m
SELF_HEALER_SANDBOX_CPU_QUOTA=50000
